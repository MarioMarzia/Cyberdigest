# CyberDigest v2.0 - Configurazione
# Copia questo file in .env e inserisci i tuoi valori

# === OBBLIGATORI ===

# Telegram Bot (ottieni da @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Groq API (ottieni da https://console.groq.com - gratuito)
GROQ_API_KEY=gsk_your_groq_api_key_here

# === OPZIONALI ===

# Ollama URL (default: localhost)
# OLLAMA_URL=http://127.0.0.1:11434/api/generate

# Gemini API (backup, non necessario se usi Groq)
# GEMINI_API_KEY=your_gemini_api_key_here
